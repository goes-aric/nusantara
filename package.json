{
  "name": "static-product-website",
  "version": "1.0.0",
  "description": "Static product website with Node.js + TailwindCSS",
  "scripts": {
    "build:css": "tailwindcss -i ./src/input.css -o ./public/output.css",
    "build:html": "node build.js",
    "build": "npm run build:css && npm run build:html",
    "watch:css": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "start": "node server.js",
    "dev": "concurrently \"npm run watch:css\" \"node server.js\""
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tailwindcss": "^3.4.1"
  }
}
